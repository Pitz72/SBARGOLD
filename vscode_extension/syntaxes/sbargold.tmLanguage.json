{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Sbargold",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.sbargold",
                    "match": "SBARGOLD#.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.sbargold",
                    "match": "SBARGOLD(@|~|\\{|\\}|>|<|\\$|\\|)"
                },
                {
                    "name": "keyword.other.sbargold",
                    "match": "SBARGOLD(!|\\?|=|\\+|\\-|\\*|/|&|\\^|>>|<<|\\[\\]|\\[:\\]|\\.)"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.sbargold",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.sbargold",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.sbargold",
            "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        },
        "operators": {
            "name": "keyword.operator.sbargold",
            "match": "==|!=|<=|>=|<|>"
        }
    },
    "scopeName": "source.sbargold"
}